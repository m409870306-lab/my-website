.manage {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.title {
  display: block;
  font-size: 52rpx;
}

.copy {
  display: block;
  margin-top: 16rpx;
  font-size: 27rpx;
}

.image-uploader {
  height: 520rpx;
  border-radius: 30rpx;
  background: #efe4d9;
  overflow: hidden;
  border: 1rpx dashed #d8c7b2;
}

.image-uploader image {
  width: 100%;
  height: 100%;
}

.placeholder {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  color: #8a755d;
  font-size: 28rpx;
}

.placeholder text:first-child {
  font-size: 64rpx;
}

.form {
  border: 1rpx solid #eadfd4;
  border-radius: 28rpx;
  background: #ffffff;
  padding: 8rpx 28rpx;
}

.field {
  min-height: 96rpx;
  border-bottom: 1rpx solid #eee4da;
  display: grid;
  grid-template-columns: 150rpx 1fr;
  align-items: center;
  gap: 22rpx;
  color: #5f554b;
}

.field:last-child {
  border-bottom: 0;
}

.field input {
  text-align: right;
  color: #211d19;
}
